DATABASE_URL="postgresql://zen:zen@localhost:55432/zen_doctor"
# Generate with: openssl rand -base64 32
AUTH_SECRET="generate-with-npx-auth-secret"
# Generate with: openssl rand -hex 32. REQUIRED in production — backend
# refuses to boot under NODE_ENV=production without this.
SESSION_SECRET=""
# Bearer token used by Vercel Cron / GitHub Action to call the simulator
# tick endpoint. Generate with: openssl rand -hex 32. REQUIRED in
# production or the endpoint will refuse requests.
QUEUE_CRON_SECRET=""
# Comma-separated list of frontend origins allowed to call this API
# with credentials. Example: https://zen-doctor.vercel.app
ALLOWED_ORIGINS=""
# Set to "1" to disable the in-process queue simulator (used on Vercel).
QUEUE_SIMULATOR_DISABLED=""
PORT=3000

# Google OAuth credentials for sign-in integration
AUTH_GOOGLE_ID="your-google-client-id"
AUTH_GOOGLE_SECRET="your-google-client-secret"
