{
  "name": "zen-doctor",
  "version": "1.0.0",
  "description": "Hyper-local doctor discovery and real-time appointment booking platform (Next.js + Express + Postgres).",
  "private": true,
  "scripts": {
    "dev:frontend": "npm run dev --prefix frontend",
    "build:frontend": "npm run build --prefix frontend",
    "build": "npm run build:frontend",
    "start:frontend": "npm run start --prefix frontend",
    "dev:backend": "npm run start --prefix backend",
    "start:backend": "npm run db:up && node backend/scripts/wait-for-db.js && npx prisma migrate deploy --schema=backend/prisma/schema.prisma && npm run dev:backend",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "migrate:dev": "npx prisma migrate dev --schema=backend/prisma/schema.prisma",
    "migrate:deploy": "npx prisma migrate deploy --schema=backend/prisma/schema.prisma",
    "migrate:reset": "npx prisma migrate reset --force --schema=backend/prisma/schema.prisma",
    "prisma:gen": "npx prisma generate --schema=backend/prisma/schema.prisma"
  },
  "devDependencies": {
    "prisma": "^7.8.0",
    "dotenv": "^16.4.5"
  }
}
