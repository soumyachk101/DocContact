// Prisma schema for ZEN Doctor (Postgres).
//
// Tables and columns are kept snake_case via @map so the existing route
// contracts and queries map cleanly. Field names are camelCase so the
// API surface is unchanged.

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  patient
  doctor
  admin
}

enum Gender {
  male
  female
}

enum Treatment {
  Allopathy
  Homoeopathy
  Ayurvedic
}

model User {
  id           Int       @id @default(autoincrement())
  email        String    @unique
  passwordHash String    @map("password_hash")
  name         String
  role         Role      @default(patient)
  createdAt    DateTime  @default(now()) @map("created_at")
  doctor       Doctor?   @relation("DoctorToUser")
  bookings     Booking[]

  @@map("users")
}

model Doctor {
  id             String    @id
  userId         Int?      @unique @map("user_id")
  user           User?     @relation("DoctorToUser", fields: [userId], references: [id], onDelete: SetNull)
  fullName       String    @map("full_name")
  gender         Gender
  treatment      Treatment
  specialization String
  degree         String
  experience     Int       @default(1)
  location       String
  city           String
  fees           Int       @default(200)
  timings        String
  days           String
  available      Boolean   @default(true)
  isVerified     Boolean   @default(true) @map("is_verified")
  currentToken   Int       @default(0) @map("current_token")
  totalTokens    Int       @default(0) @map("total_tokens")
  maxTokens      Int       @default(30) @map("max_tokens")
  createdAt      DateTime  @default(now()) @map("created_at")
  bookings       Booking[]

  @@index([city])
  @@index([treatment])
  @@map("doctors")
}

model Booking {
  id                   String   @id
  userId               Int      @map("user_id")
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  doctorId             String   @map("doctor_id")
  doctor               Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  doctorName           String   @map("doctor_name")
  doctorSpecialization String   @map("doctor_specialization")
  doctorLocation       String   @map("doctor_location")
  doctorCity           String   @map("doctor_city")
  bookingDate          String   @map("booking_date")
  timeSlot             String   @map("time_slot")
  patientName          String   @map("patient_name")
  patientPhone         String   @map("patient_phone")
  patientAge           String   @map("patient_age")
  patientGender        String   @map("patient_gender")
  tokenNumber          Int      @map("token_number")
  bookedAt             DateTime @default(now()) @map("booked_at")

  @@index([userId])
  @@index([doctorId])
  @@map("bookings")
}
